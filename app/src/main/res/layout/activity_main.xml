<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/conversor_de_moeda"
            android:textSize="26sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginBottom="24dp"
            android:contentDescription="@string/icone_nota"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/coin" />

        <TextView
            android:id="@+id/textView2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/moeda"
            android:textColor="@color/text_secondary" />

        <RadioGroup
            android:id="@+id/radioGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rd_dol"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/dolar" />

            <RadioButton
                android:id="@+id/rd_euro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/euro" />

            <RadioButton
                android:id="@+id/rd_btc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bitcoin" />
        </RadioGroup>

        <EditText
            android:id="@+id/id_val_cotacao"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="16dp"
            android:hint="@string/cotacao_moeda"
            android:inputType="numberDecimal"
            android:background="@drawable/bg_input"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:padding="12dp" />

        <EditText
            android:id="@+id/id_val_reais"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="24dp"
            android:hint="@string/valor_em_reais"
            android:inputType="numberDecimal"
            android:background="@drawable/bg_input"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:padding="12dp" />

        <Button
            android:id="@+id/id_btn_converter"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="@string/converter"
            android:background="@drawable/bg_button"
            android:textColor="@color/black"
            android:padding="12dp" />

        <TextView
            android:id="@+id/id_resultado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>